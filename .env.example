# =============================================================
# AegisAI Platform — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================

# ─── Application ─────────────────────────────────────────────
APP_NAME=AegisAI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# ─── Security ────────────────────────────────────────────────
# IMPORTANT: Generate a strong key for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-IN-PRODUCTION-USE-STRONG-RANDOM-KEY-AT-LEAST-32-CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Google Gemini AI ─────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
# Leave empty to run in mock mode (AI features disabled but app still functional)
GEMINI_API_KEY=

# ─── Google Maps ─────────────────────────────────────────────
# Enable for real geocoding/directions. Leave empty for mock mode.
GOOGLE_MAPS_API_KEY=

# ─── OpenWeatherMap ──────────────────────────────────────────
# Get from: https://openweathermap.org/api
# Leave empty for mock weather data
OPENWEATHER_API_KEY=

# ─── Google Cloud Firestore ───────────────────────────────────
# Leave empty to use in-memory MockDB (recommended for local dev)
FIRESTORE_PROJECT_ID=
FIRESTORE_CREDENTIALS_PATH=

# ─── Twilio SMS ──────────────────────────────────────────────
# For production SMS alerts. Leave empty to log to console.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── SendGrid Email ──────────────────────────────────────────
# For production email alerts. Leave empty to log to console.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@aegisai.example.com

# ─── CORS / URLs ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ─── Rate Limits ─────────────────────────────────────────────
RATE_LIMIT_PUBLIC=20/minute
RATE_LIMIT_AUTHENTICATED=100/minute
RATE_LIMIT_EMERGENCY=5/minute

# ─── Frontend Environment Variables ──────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
